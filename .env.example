PORT=3000
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/dbname
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username

# Optional: run bot as separate worker
BOT_MODE=api
START_BOT_IN_PROCESS=true

# Security / observability
MAX_RESULT_TIMESTAMP_DIFF_MS=180000
LOG_LEVEL=info

CORS_ALLOWED_ORIGINS=

# CORS preview mode: none | strict | wildcard
CORS_PREVIEW_MODE=none

# Legacy compatibility (not recommended)
LEGACY_USE_RIDE_NO_AUTH=false
